# ============================================
# CONFIGURAÇÕES GERAIS DO SISTEMA
# ============================================
TZ=America/Sao_Paulo
SERVER_URL=http://localhost:3000
CLIENT_NAME=evolution

# ============================================
# SERVIDOR EVOLUTION API
# ============================================
SERVER_PORT=3000
HOST=0.0.0.0

# ============================================
# AUTENTICAÇÃO E SEGURANÇA
# ============================================
JWT_SECRET=your_secret_key_is_here
GLOBAL_API_KEY=your_secret_key_is_here

# ============================================
# BANCO DE DADOS POSTGRESQL
# ============================================
DB_CONNECTION_TYPE=postgres
DATABASE_SAVE_MESSAGES=true
DATABASE_SAVE_CHATS=true

# Configurações base do PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=evolution
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URLs de conexão (construídas automaticamente a partir das variáveis acima)
POSTGRES_AUTH_DB=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable
POSTGRES_USERS_DB=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

# ============================================
# REDIS (Cache e Sessões)
# ============================================
REDIS_ENABLED=true
REDIS_PASSWORD=redis123
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URI=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ============================================
# NATS (Sistema de Eventos)
# ============================================
NATS_HOST=nats-server
NATS_PORT=4222
NATS_URL=nats://${NATS_HOST}:${NATS_PORT}
NATS_URI=nats://${NATS_HOST}:${NATS_PORT}

# ============================================
# RABBITMQ (Desabilitado - usando NATS)
# ============================================
RABBITMQ_ENABLED=false

# ============================================
# LOGS E DEBUG
# ============================================
LOG_LEVEL=info
LOGTYPE=console
WADEBUG=DEBUG

# ============================================
# CONFIGURAÇÕES DO N8N
# ============================================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=${POSTGRES_HOST}
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
DB_POSTGRESDB_PORT=${POSTGRES_PORT}

N8N_LOG_LEVEL=debug
N8N_SECURE_COOKIE=false
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true
GENERIC_TIMEZONE=America/Sao_Paulo

# Autenticação básica para o n8n
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=admin123

N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678

# ============================================
# CONFIGURAÇÕES ADICIONAIS
# ============================================
# Timeout para requisições
REQUEST_TIMEOUT=30000

# Limite de upload
MAX_UPLOAD_SIZE=50MB

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_CREDENTIALS=true